  "keyFeatures": [
    "Type-safe SQL query builder with full TypeScript support",
    "Support for PostgreSQL, MySQL, and SQLite databases",
    "Zero dependencies and tree-shakeable at ~7.4kb minified+gzipped",
    "SQL-like and relational query APIs",
    "Automatic migrations with Drizzle Kit",
    "Works in Node.js, Bun, Deno, Cloudflare Workers, and browsers",
    "Support for serverless databases (Neon, Turso, PlanetScale, Vercel Postgres)",
    "Schema validation with Zod, Valibot, TypeBox, and ArkType",
    "Database seeding utilities with Drizzle Seed",
    "Visual database browser with Drizzle Studio"
  ],
  "publicApiSurface": [
    "drizzle() - Create database instance",
    "pgTable() - Define PostgreSQL table",
    "mysqlTable() - Define MySQL table",
    "sqliteTable() - Define SQLite table",
    "select() - SELECT query builder",
    "insert() - INSERT query builder",
    "update() - UPDATE query builder",
    "delete() - DELETE query builder",
    "relations() - Define table relations",
    "sql - Raw SQL template tag",
    "eq(), ne(), gt(), lt(), gte(), lte() - SQL operators",
    "and(), or(), not() - Logical operators",
    "migrate() - Run migrations",
    "transaction() - Execute transactions",
    "serial(), integer(), varchar(), text(), boolean(), timestamp() - Column types",
    "primaryKey(), foreignKey(), unique(), index() - Constraints",
    "pgSchema() - PostgreSQL schema namespaces",
    "prepare() - Prepared statements",
    ".$with() - Common Table Expressions (CTEs)",
    ".$dynamic() - Dynamic query building"
  ]
}
